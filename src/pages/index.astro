---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import MainLayout from "../layouts/MainLayout.astro";
import { SITE_CONFIG } from "../config";
import me from "../assets/me.jpg";

const projects = await getCollection("projects");
const featuredProjects = projects
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
const projectCols = Math.min(featuredProjects.length, 3);
---

<MainLayout title="Home">
  <section class="hero">
    <div class="hero-content">
      <span class="eyebrow">Available for work</span>
      <h1>Hi, I'm Zherish</h1>
      <hr class="accent-rule" />
      <p class="hero-tagline">
      A passionate engineer building automated systems that work,<br>so you don't have to.
      </p>
      <div class="hero-cta">
        <a href="/projects" class="button">View My Work</a>
        <a href="/zherishgalvinmayordo-cv.pdf" class="button button-secondary" download>Download CV</a>
      </div>
    </div>
    <div class="hero-portrait">
      <div class="hero-img-frame">
        <Image src={me} alt="Zherish Galvin Mayordo" width={640} height={640} loading="eager" />
      </div>
      <span class="badge badge-available">
        <span class="badge-dot"></span>Available For Work
      </span>
      <span class="badge badge-location">📍 Philippines</span>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <span class="eyebrow">What I offer</span>
      <h2>My Services</h2>
      <hr class="rule" />
    </div>
    <div class="services-list">
      {SITE_CONFIG.services.map((service) => (
        <div class="service-row">
          <div class="service-icon">{service.icon}</div>
          <div class="service-body">
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <span class="eyebrow">Selected work</span>
      <h2>Projects</h2>
      <hr class="rule" />
      <a href="/projects" class="section-link">View all →</a>
    </div>
    <div class="projects-grid" data-cols={projectCols}>
      {
        featuredProjects.length > 0 ? (
          featuredProjects.map((project) => (
            <article class="project-card">
              <a href={`/projects/${project.id}`} class="project-link">
                {project.data.coverImage && (
                  <div class="project-image">
                    <Image src={project.data.coverImage} alt={project.data.title} width={1200} height={675} widths={[360, 600, 900, 1200]} sizes="(max-width: 768px) 100vw, 380px" quality={90} loading="lazy" />
                  </div>
                )}
                <div class="project-content">
                  <div class="project-tags">
                    {project.data.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
                  </div>
                  <h3>{project.data.title}</h3>
                  <p>{project.data.description}</p>
                </div>
              </a>
            </article>
          ))
        ) : (
          <p class="empty-state">No projects yet. Check back soon!</p>
        )
      }
    </div>
  </section>

  <style>
    .hero {
      padding: var(--space-3xl) 0;
      display: flex;
      gap: var(--space-2xl);
      align-items: center;
      justify-content: space-between;
    }

    .hero-content {
      max-width: 720px;
      text-align: left;
    }

    .hero-portrait {
      position: relative;
      flex-shrink: 0;
    }

    .hero-img-frame {
      width: clamp(220px, 24vw, 320px);
      height: clamp(220px, 24vw, 320px);
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid var(--border);
      box-shadow: 0 0 0 1px var(--border);
      position: relative;
    }

    .hero-img-frame :global(img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .badge {
      position: absolute;
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      padding: 0.375rem 0.7rem;
      font-size: var(--text-xs);
      font-weight: 600;
      border-radius: 999px;
      background: color-mix(in srgb, var(--bg) 85%, transparent);
      border: 1px solid var(--border);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      color: var(--text-primary);
      white-space: nowrap;
    }

    .badge-available {
      top: var(--space-sm);
      left: var(--space-sm);
    }

    .badge-dot {
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 50%;
      background: #22c55e;
      display: inline-block;
      animation: badge-pulse 2s ease-in-out infinite;
    }

    @keyframes badge-pulse {
      0%,
      100% {
        opacity: 1;
        box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.6);
      }
      50% {
        opacity: 0.7;
        box-shadow: 0 0 0 4px rgba(34, 197, 94, 0);
      }
    }

    .badge-location {
      bottom: var(--space-sm);
      right: var(--space-sm);
    }

    .hero h1 {
      font-size: var(--text-4xl);
      margin: 0 0 0;
      color: var(--text-primary);
    }

    .hero-tagline {
      font-size: var(--text-lg);
      color: var(--text-secondary);
      margin: 0 0 var(--space-xl);
      line-height: 1.6;
    }

    .hero-cta {
      display: flex;
      gap: var(--space-md);
      justify-content: flex-start;
      flex-wrap: wrap;
    }

    .section {
      margin-top: var(--space-3xl);
    }

    .section-header {
      margin-bottom: var(--space-xl);
    }

    .section-header h2 {
      margin: 0 0 0;
    }

    .section-link {
      display: inline-block;
      color: var(--accent);
      text-decoration: none;
      font-weight: 500;
      font-size: var(--text-sm);
      transition: color var(--transition-fast);
      margin-top: var(--space-sm);
    }

    .section-link:hover {
      color: var(--accent-hover);
    }

    .services-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--space-lg);
    }

    .service-row {
      display: flex;
      gap: var(--space-lg);
      padding: var(--space-lg);
      border-radius: var(--border-radius-lg);
      border: 1px solid var(--border);
      border-top: 2px solid var(--accent);
      transition: border-color var(--transition-fast);
      background-color: var(--bg);
      align-items: flex-start;
    }

    .service-row:hover {
      border-color: var(--border-hover);
      border-top-color: var(--accent);
    }

    .service-icon {
      font-size: 2.5rem;
      flex-shrink: 0;
      line-height: 1;
    }

    .service-body h3 {
      margin: 0 0 var(--space-sm);
      font-size: var(--text-lg);
    }

    .service-body p {
      margin: 0;
      color: var(--text-secondary);
      font-size: var(--text-sm);
      line-height: 1.6;
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--space-xl);
    }

    .projects-grid[data-cols="1"] {
      max-width: 640px;
      margin-inline: auto;
    }

    .project-card {
      border-radius: var(--border-radius-lg);
      overflow: hidden;
      background-color: var(--bg);
      border: 1px solid var(--border);
      border-top: 2px solid var(--accent);
      transition: border-color var(--transition-fast);
    }

    .project-card:hover {
      border-color: var(--border-hover);
      border-top-color: var(--accent);
    }

    .project-link {
      text-decoration: none;
      color: inherit;
      display: block;
      height: 100%;
    }

    .project-image {
      aspect-ratio: 16 / 9;
      overflow: hidden;
      background-color: var(--bg-secondary);
    }

    .project-image :global(img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .project-content {
      padding: var(--space-lg);
    }

    .project-tags {
      display: flex;
      gap: var(--space-sm);
      margin-bottom: var(--space-md);
      flex-wrap: wrap;
    }

    .project-tags span {
      font-size: var(--text-xs);
      padding: 0.125rem 0.5rem;
      border: 1px solid var(--border);
      border-radius: var(--border-radius);
      color: var(--text-secondary);
      background-color: transparent;
    }

    .project-content h3 {
      margin: 0 0 var(--space-sm);
      font-size: var(--text-lg);
      transition: color var(--transition-fast);
    }

    .project-card:hover .project-content h3 {
      color: var(--accent);
    }

    .project-content p {
      margin: 0;
      color: var(--text-secondary);
      font-size: var(--text-sm);
      line-height: 1.6;
    }

    .empty-state {
      text-align: center;
      color: var(--text-muted);
      padding: var(--space-3xl);
      grid-column: 1 / -1;
    }

    @media (max-width: 768px) {
      .hero {
        flex-direction: column;
        align-items: flex-start;
        gap: var(--space-xl);
      }

      .hero-portrait {
        align-self: center;
      }

      .hero h1 {
        font-size: var(--text-3xl);
      }
    }
  </style>
</MainLayout>
