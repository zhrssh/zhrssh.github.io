---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";

const blogs = await getCollection("blog");
const latestBlog = blogs.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)[0];

const projects = await getCollection("projects");
const latestProject = projects.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)[0];
---

<MainLayout title="Home">
  <img src="https://placehold.co/300x300?text=Profile+Picture" alt="Profile Picture" style="width: 300px; height: 300px; border-radius: 50%; object-fit: cover; margin-bottom: 2rem;" />
  <h1>Welcome to my portfolio!</h1>

  <section>
    <h2>Latest Blog</h2>
    {
      latestBlog ? (
        <div>
          <h3>
            <a href={`/blog/${latestBlog.id}`}>{latestBlog.data.title}</a>
          </h3>
          <p>{latestBlog.data.description}</p>
        </div>
      ) : (
        <p>No blog posts yet.</p>
      )
    }
  </section>

  <section>
    <h2>Recently Deployed Project</h2>
    {
      latestProject ? (
        <div>
          <h3>
            <a href={`/projects/${latestProject.id}`}>
              {latestProject.data.title}
            </a>
          </h3>
          <p>{latestProject.data.description}</p>
        </div>
      ) : (
        <p>No projects yet.</p>
      )
    }
  </section>
</MainLayout>
