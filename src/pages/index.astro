---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";
import { SITE_CONFIG } from "../config";

const projects = await getCollection("projects");
const featuredProjects = projects
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
const projectCols = Math.min(featuredProjects.length, 3);
---

<MainLayout title="Home">
  <section class="hero">
    <div class="hero-content">
      <div class="hero-badge animate-in">Available for work</div>
      <h1 class="animate-in stagger-1">Hi, I'm <span class="accent">Zherish</span></h1>
      <p class="hero-tagline animate-in stagger-2">
        A passionate developer crafting modern web experiences with clean code and thoughtful design.
      </p>
      <div class="hero-cta animate-in stagger-3">
        <a href="/projects" class="button">View My Work</a>
        <a href="/zherishgalvinmayordo-cv.pdf" class="button button-secondary" download>Download CV</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>My Services</h2>
    </div>
    <div class="services-list">
      {SITE_CONFIG.services.slice(0, 2).map((service) => (
        <div class="service-row">
          <div class="service-icon">{service.icon}</div>
          <div class="service-body">
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Projects</h2>
      <a href="/projects" class="section-link">View all →</a>
    </div>
    <div class="projects-grid" data-cols={projectCols}>
      {
        featuredProjects.length > 0 ? (
          featuredProjects.map((project) => (
            <article class="project-card">
              <a href={`/projects/${project.id}`} class="project-link">
                {project.data.coverImage && (
                  <div class="project-image">
                    <img src={project.data.coverImage} alt={project.data.title} loading="lazy" />
                  </div>
                )}
                <div class="project-content">
                  <div class="project-tags">
                    {project.data.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
                  </div>
                  <h3>{project.data.title}</h3>
                  <p>{project.data.description}</p>
                </div>
              </a>
            </article>
          ))
        ) : (
          <p class="empty-state">No projects yet. Check back soon!</p>
        )
      }
    </div>
  </section>

  <style>
    .hero {
      padding: var(--space-3xl) 0;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: clamp(280px, 40vw, 600px);
      height: clamp(280px, 40vw, 600px);
      background: radial-gradient(circle farthest-side, var(--accent) 0%, transparent 70%);
      mask-image: radial-gradient(circle, black 55%, transparent 100%);
      -webkit-mask-image: radial-gradient(circle, black 55%, transparent 100%);
      opacity: 0.1;
      filter: blur(100px);
      z-index: 0;
      animation: float-1 8s ease-in-out infinite alternate;
      pointer-events: none;
    }

    @keyframes float-1 {
      from { transform: translate(0, 0); }
      to { transform: translate(-40px, 30px); }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero::before {
        animation: none;
      }
    }

    [data-theme='dark'] .hero::before {
      opacity: 0.15;
    }

    .hero-content {
      max-width: 720px;
      position: relative;
      z-index: 1;
      text-align: left;
    }

    .hero-badge {
      display: inline-block;
      padding: var(--space-xs) var(--space-md);
      background-color: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 100px;
      font-size: var(--text-sm);
      color: var(--text-secondary);
      margin-bottom: var(--space-lg);
      opacity: 0;
    }

    .hero h1 {
      font-size: var(--text-4xl);
      margin-bottom: var(--space-lg);
      opacity: 0;
    }

    .accent {
      color: var(--accent);
    }

    .hero-tagline {
      font-size: var(--text-lg);
      color: var(--text-secondary);
      margin-bottom: var(--space-xl);
      line-height: 1.6;
      opacity: 0;
    }

    .hero-cta {
      display: flex;
      gap: var(--space-md);
      justify-content: flex-start;
      flex-wrap: wrap;
      opacity: 0;
    }

    .section {
      margin-top: var(--space-3xl);
    }

    .section:first-of-type {
      margin-top: var(--space-2xl);
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: var(--space-xl);
    }

    .section-header h2 {
      margin: 0;
    }

    .section-link {
      display: inline-block;
      color: var(--accent);
      text-decoration: none;
      font-weight: 500;
      font-size: var(--text-sm);
      transition: all var(--transition-fast);
    }

    .section-link:hover {
      color: var(--accent-hover);
      transform: translateX(4px);
    }

    .services-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--space-lg);
    }

    .service-row {
      display: flex;
      gap: var(--space-lg);
      padding: var(--space-lg);
      border-radius: var(--border-radius-lg);
      border: 1px solid var(--border);
      transition: all var(--transition);
      background-color: var(--bg);
      align-items: flex-start;
    }

    .service-row:hover {
      border-color: var(--accent);
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }

    .service-icon {
      font-size: 2.5rem;
      flex-shrink: 0;
      line-height: 1;
    }

    .service-body h3 {
      margin: 0 0 var(--space-sm);
      font-size: var(--text-lg);
    }

    .service-body p {
      margin: 0;
      color: var(--text-secondary);
      font-size: var(--text-sm);
      line-height: 1.6;
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--space-xl);
    }

    .projects-grid[data-cols="1"] {
      max-width: 640px;
      margin-inline: auto;
    }

    .project-card {
      border-radius: var(--border-radius-lg);
      overflow: hidden;
      background-color: var(--bg);
      border: 1px solid var(--border);
      transition: all var(--transition);
    }

    .project-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-lg);
      border-color: var(--accent);
    }

    .project-link {
      text-decoration: none;
      color: inherit;
      display: block;
      height: 100%;
    }

    .project-image {
      aspect-ratio: 16 / 9;
      overflow: hidden;
      background-color: var(--bg-secondary);
    }

    .project-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform var(--transition-slow);
    }

    .project-card:hover .project-image img {
      transform: scale(1.05);
    }

    .project-content {
      padding: var(--space-lg);
    }

    .project-tags {
      display: flex;
      gap: var(--space-sm);
      margin-bottom: var(--space-md);
      flex-wrap: wrap;
    }

    .project-tags span {
      font-size: var(--text-xs);
      padding: var(--space-xs) var(--space-sm);
      background-color: var(--bg-secondary);
      border-radius: 4px;
      color: var(--text-secondary);
    }

    .project-content h3 {
      margin: 0 0 var(--space-sm);
      font-size: var(--text-lg);
    }

    .project-content p {
      margin: 0;
      color: var(--text-secondary);
      font-size: var(--text-sm);
      line-height: 1.6;
    }

    .empty-state {
      text-align: center;
      color: var(--text-muted);
      padding: var(--space-3xl);
      grid-column: 1 / -1;
    }

    @media (max-width: 768px) {
      .hero h1 {
        font-size: var(--text-3xl);
      }

      .section-header {
        flex-direction: column;
        align-items: flex-start;
        gap: var(--space-sm);
      }
    }
  </style>
</MainLayout>
