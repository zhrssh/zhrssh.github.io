---
import { type CollectionEntry, getCollection, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import { getReadingTime } from "../../utils/readingTime";

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<"blog"> };
const { entry } = Astro.props;
const { Content } = await render(entry);
const readingTime = getReadingTime(entry.body || "");
---

<MainLayout title={entry.data.title}>
  <article class="post">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={entry.data.date.toISOString()}>
          {entry.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </time>
        <span class="meta-dot">•</span>
        <span>{readingTime} min read</span>
        <span class="meta-dot">•</span>
        <span>By {entry.data.author}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="post-description">{entry.data.description}</p>
      <div class="post-tags">
        {entry.data.tags.map(tag => <span>{tag}</span>)}
      </div>
    </header>

    {entry.data.coverImage && (
      <div class="post-cover">
        <img src={entry.data.coverImage} alt={entry.data.title} />
      </div>
    )}

    <div class="post-content">
      <Content />
    </div>
  </article>

  <style>
    .post {
      max-width: 720px;
      margin: 0 auto;
    }

    .post-header {
      margin-bottom: var(--space-2xl);
      padding-bottom: var(--space-2xl);
      border-bottom: 1px solid var(--border);
    }

    .post-meta {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      font-size: var(--text-sm);
      color: var(--text-muted);
      margin-bottom: var(--space-lg);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .meta-dot {
      color: var(--border);
    }

    .post-header h1 {
      font-size: var(--text-4xl);
      margin: 0 0 var(--space-lg);
      line-height: 1.2;
    }

    .post-description {
      font-size: var(--text-lg);
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0 0 var(--space-xl);
    }

    .post-tags {
      display: flex;
      gap: var(--space-sm);
      flex-wrap: wrap;
    }

    .post-tags span {
      font-size: var(--text-xs);
      padding: var(--space-xs) var(--space-md);
      background-color: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 100px;
      color: var(--text-secondary);
      font-weight: 500;
    }

    .post-cover {
      margin-bottom: var(--space-2xl);
      border-radius: var(--border-radius-lg);
      overflow: hidden;
    }

    .post-cover img {
      width: 100%;
      height: auto;
      display: block;
    }

    .post-content {
      font-size: var(--text-base);
      line-height: 1.8;
    }

    .post-content :global(h2) {
      font-size: var(--text-2xl);
      margin-top: var(--space-2xl);
      margin-bottom: var(--space-md);
    }

    .post-content :global(h3) {
      font-size: var(--text-xl);
      margin-top: var(--space-xl);
      margin-bottom: var(--space-md);
    }

    .post-content :global(p) {
      margin-bottom: var(--space-lg);
      color: var(--text-secondary);
    }

    .post-content :global(a) {
      color: var(--accent);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .post-content :global(a:hover) {
      color: var(--accent-hover);
    }

    .post-content :global(ul),
    .post-content :global(ol) {
      margin-bottom: var(--space-lg);
      padding-left: var(--space-xl);
      color: var(--text-secondary);
    }

    .post-content :global(li) {
      margin-bottom: var(--space-sm);
    }

    .post-content :global(blockquote) {
      margin: var(--space-xl) 0;
      padding: var(--space-lg) var(--space-xl);
      background-color: var(--bg-secondary);
      border-left: 4px solid var(--accent);
      border-radius: 0 var(--border-radius) var(--border-radius) 0;
      font-style: italic;
      color: var(--text-secondary);
    }

    .post-content :global(code) {
      font-family: var(--font-mono);
      font-size: 0.9em;
      padding: 0.2em 0.4em;
      background-color: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 4px;
    }

    .post-content :global(pre) {
      margin: var(--space-xl) 0;
      padding: var(--space-lg);
      background-color: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: var(--border-radius);
      overflow-x: auto;
    }

    .post-content :global(pre code) {
      padding: 0;
      background: none;
      border: none;
      font-size: var(--text-sm);
    }

    .post-content :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: var(--border-radius);
      margin: var(--space-xl) 0;
    }

    @media (max-width: 768px) {
      .post-header h1 {
        font-size: var(--text-3xl);
      }

      .post-meta {
        flex-wrap: wrap;
      }
    }
  </style>
</MainLayout>
