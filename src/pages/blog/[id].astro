---
import { type CollectionEntry, getCollection, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import { getReadingTime } from "../../utils/readingTime";

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<"blog"> };
const { entry } = Astro.props;
const { Content } = await render(entry);
const readingTime = getReadingTime(entry.body || "");
---

<MainLayout title={entry.data.title}>
  <article>
    <header class="hero">
      <h1>{entry.data.title}</h1>
      <p class="description">{entry.data.description}</p>
      {entry.data.coverImage && <img src={entry.data.coverImage} alt={entry.data.title} class="cover-image" />}
      <p><em>By {entry.data.author} • {entry.data.date.toDateString()} • {readingTime} min read</em></p>
      <div class="tags">
        {entry.data.tags.map(tag => <span>#{tag}</span>)}
      </div>
    </header>
    <Content />
  </article>
</MainLayout>

<style>
  .hero {
    position: static;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #eee;
  }
  .description {
    font-size: 1.2rem;
    color: #555;
  }
  .cover-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 8px;
    margin: 1rem 0;
  }
  .tags {
    margin: 1rem 0;
    display: flex;
    gap: 0.5rem;
    font-size: 0.9rem;
  }
  .tags span {
    background: #eee;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }
</style>
