---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";

const allBlogs = await getCollection("blog");
---

<MainLayout title="Blog">
  <h1>Blog Posts</h1>
  <ul class="blog-list">
    {
      allBlogs.map((post) => (
        <li class="blog-card">
          <a href={`/blog/${post.id}`} class="blog-link">
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <small>Published on: {post.data.date.toLocaleDateString()}</small>
          </a>
        </li>
      ))
    }
  </ul>
  <style>
    .blog-list {
      list-style: none;
      padding: 0;
    }
    .blog-card {
      margin-bottom: 2rem;
      border: 1px solid #ccc;
      padding: 1rem;
      border-radius: 8px;
    }
    .blog-link {
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .blog-link:hover {
      background-color: #f9f9f9;
    }
  </style>
</MainLayout>
