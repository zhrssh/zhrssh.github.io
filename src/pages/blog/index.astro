---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import { getReadingTime } from "../../utils/readingTime";

const allBlogs = await getCollection("blog");
const allTags = [...new Set(allBlogs.flatMap((p) => p.data.tags))].sort();
---

<MainLayout title="Blog">
  <div class="page-header">
    <span class="eyebrow">Writing</span>
    <h1>Blog</h1>
    <hr class="rule" />
    <p class="page-description">Thoughts, tutorials, and insights from my development journey.</p>
  </div>

  <section class="controls">
    <div class="search-wrapper">
      <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input type="text" id="search-input" placeholder="Search posts..." />
    </div>
    <select id="tag-filter">
      <option value="all">All Tags</option>
      {allTags.map((tag) => <option value={tag}>{tag}</option>)}
    </select>
    <select id="sort-select">
      <option value="newest">Newest First</option>
      <option value="oldest">Oldest First</option>
      <option value="title">Alphabetical</option>
    </select>
  </section>

  <ul class="blog-list" id="blog-list">
    {
      allBlogs
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
        .map((post) => (
          <li class="blog-item" data-tags={post.data.tags.join(" ")} data-title={post.data.title} data-date={post.data.date.getTime()}>
            <a href={`/blog/${post.id}`} class="blog-link">
              <div class="blog-content">
                <div class="blog-meta">
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>
                  <span class="meta-dot">•</span>
                  <span>{getReadingTime(post.body || "")} min read</span>
                  <span class="meta-dot">•</span>
                  <span>{post.data.author}</span>
                </div>
                <h2 class="blog-title">{post.data.title}</h2>
                <p class="blog-description">{post.data.description}</p>
                <div class="blog-footer">
                  <div class="blog-tags">
                    {post.data.tags.map((tag) => <span>{tag}</span>)}
                  </div>
                  <span class="read-more">Read more →</span>
                </div>
              </div>
            </a>
          </li>
        ))
    }
  </ul>

  <script>
    const searchInput = document.getElementById("search-input") as HTMLInputElement;
    const tagFilter = document.getElementById("tag-filter") as HTMLSelectElement;
    const sortSelect = document.getElementById("sort-select") as HTMLSelectElement;
    const blogList = document.getElementById("blog-list") as HTMLUListElement;
    let blogCards = Array.from(document.querySelectorAll(".blog-item")) as HTMLElement[];

    function updateView() {
      const searchTerm = searchInput.value.toLowerCase();
      const selectedTag = tagFilter.value;
      const sortBy = sortSelect.value;

      let filtered = blogCards.filter((card) => {
        const title = card.getAttribute("data-title")!.toLowerCase();
        const tags = card.getAttribute("data-tags")!;
        const matchesSearch = title.includes(searchTerm);
        const matchesTag = selectedTag === "all" || tags.split(" ").includes(selectedTag);
        return matchesSearch && matchesTag;
      });

      filtered.sort((a, b) => {
        if (sortBy === "newest") return parseInt(b.getAttribute("data-date")!) - parseInt(a.getAttribute("data-date")!);
        if (sortBy === "oldest") return parseInt(a.getAttribute("data-date")!) - parseInt(b.getAttribute("data-date")!);
        if (sortBy === "title") return a.getAttribute("data-title")!.localeCompare(b.getAttribute("data-title")!);
        return 0;
      });

      blogList.innerHTML = "";
      filtered.forEach((card) => blogList.appendChild(card));
    }

    searchInput.addEventListener("input", updateView);
    tagFilter.addEventListener("change", updateView);
    sortSelect.addEventListener("change", updateView);
  </script>

  <style>
    .page-header {
      margin-bottom: var(--space-2xl);
    }

    .page-header h1 {
      margin: 0 0 0;
    }

    .page-description {
      color: var(--text-secondary);
      font-size: var(--text-lg);
      margin: 0;
    }

    .controls {
      margin-bottom: var(--space-2xl);
      display: flex;
      gap: var(--space-md);
      flex-wrap: wrap;
      padding: var(--space-md);
      background-color: var(--bg);
      border-radius: var(--border-radius);
      border: 1px solid var(--border);
    }

    .search-wrapper {
      position: relative;
      flex: 1;
      min-width: 200px;
    }

    .search-icon {
      position: absolute;
      left: var(--space-md);
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-muted);
      pointer-events: none;
    }

    input, select {
      padding: 0.375rem var(--space-md);
      border: 1px solid var(--border);
      border-radius: var(--border-radius);
      background-color: var(--bg);
      color: var(--text-primary);
      font-size: var(--text-sm);
      transition: border-color var(--transition-fast);
      width: 100%;
    }

    .search-wrapper input {
      padding-left: var(--space-2xl);
    }

    input:focus, select:focus {
      outline: none;
      border-color: var(--accent);
    }

    select {
      cursor: pointer;
      min-width: 140px;
      width: auto;
    }

    .blog-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .blog-item {
      border-bottom: 1px solid var(--border);
      background-color: var(--bg);
      transition: border-color var(--transition-fast);
    }

    .blog-link {
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .blog-content {
      padding: var(--space-lg) 0;
    }

    .blog-meta {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      font-size: var(--text-xs);
      color: var(--text-muted);
      margin-bottom: var(--space-sm);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .meta-dot {
      color: var(--border);
    }

    .blog-title {
      margin: 0 0 var(--space-sm);
      font-size: var(--text-xl);
      line-height: 1.3;
      color: var(--text-primary);
      transition: color var(--transition-fast);
      border-bottom: 2px solid transparent;
      display: inline-block;
    }

    .blog-item:hover .blog-title {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }

    .blog-description {
      color: var(--text-secondary);
      margin: 0 0 var(--space-md);
      font-size: var(--text-base);
      line-height: 1.6;
    }

    .blog-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--space-md);
    }

    .blog-tags {
      display: flex;
      gap: var(--space-sm);
      flex-wrap: wrap;
    }

    .blog-tags span {
      font-size: var(--text-xs);
      padding: 0.125rem 0.5rem;
      border: 1px solid var(--border);
      border-radius: var(--border-radius);
      color: var(--text-secondary);
      background-color: transparent;
    }

    .read-more {
      display: inline-block;
      color: var(--accent);
      font-size: var(--text-sm);
      font-weight: 500;
      white-space: nowrap;
      transition: color var(--transition-fast);
    }

    .blog-item:hover .read-more {
      color: var(--accent-hover);
    }

    @media (max-width: 768px) {
      .controls {
        flex-direction: column;
      }

      select {
        width: 100%;
      }

      .blog-footer {
        flex-direction: column;
        align-items: flex-start;
        gap: var(--space-md);
      }
    }
  </style>
</MainLayout>
