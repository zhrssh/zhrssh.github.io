---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import { getReadingTime } from "../../utils/readingTime";

const allBlogs = await getCollection("blog");
const allTags = [...new Set(allBlogs.flatMap((p) => p.data.tags))].sort();
---

<MainLayout title="Blog">
  <h1>Blog Posts</h1>

  <section class="controls">
    <input type="text" id="search-input" placeholder="Search blogs..." />
    <select id="tag-filter">
      <option value="all">All Tags</option>
      {allTags.map((tag) => <option value={tag}>{tag}</option>)}
    </select>
    <select id="sort-select">
      <option value="newest">Newest to Oldest</option>
      <option value="oldest">Oldest to Newest</option>
      <option value="title">Title</option>
    </select>
  </section>

  <ul class="blog-list" id="blog-list">
    {
      allBlogs
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
        .map((post) => (
          <li class="blog-item" data-tags={post.data.tags.join(" ")} data-title={post.data.title} data-date={post.data.date.getTime()}>
            <a href={`/blog/${post.id}`} class="blog-link">
              <div class="blog-meta">
                <span class="blog-date">{post.data.date.toLocaleDateString()}</span>
                <span>• {getReadingTime(post.body || "")} min read</span>
                <span>• By {post.data.author}</span>
              </div>
              <h3 class="blog-title">{post.data.title}</h3>
              <p class="blog-desc">{post.data.description}</p>
              <div class="tags">
                {post.data.tags.map((tag) => <span>#{tag}</span>)}
              </div>
            </a>
          </li>
        ))
    }
  </ul>

  <script>
    const searchInput = document.getElementById("search-input") as HTMLInputElement;
    const tagFilter = document.getElementById("tag-filter") as HTMLSelectElement;
    const sortSelect = document.getElementById("sort-select") as HTMLSelectElement;
    const blogList = document.getElementById("blog-list") as HTMLUListElement;
    let blogCards = Array.from(document.querySelectorAll(".blog-item")) as HTMLElement[];

    function updateView() {
      const searchTerm = searchInput.value.toLowerCase();
      const selectedTag = tagFilter.value;
      const sortBy = sortSelect.value;

      let filtered = blogCards.filter((card) => {
        const title = card.getAttribute("data-title")!.toLowerCase();
        const tags = card.getAttribute("data-tags")!;
        const matchesSearch = title.includes(searchTerm);
        const matchesTag = selectedTag === "all" || tags.split(" ").includes(selectedTag);
        return matchesSearch && matchesTag;
      });

      filtered.sort((a, b) => {
        if (sortBy === "newest") return parseInt(b.getAttribute("data-date")!) - parseInt(a.getAttribute("data-date")!);
        if (sortBy === "oldest") return parseInt(a.getAttribute("data-date")!) - parseInt(b.getAttribute("data-date")!);
        if (sortBy === "title") return a.getAttribute("data-title")!.localeCompare(b.getAttribute("data-title")!);
        return 0;
      });

      blogList.innerHTML = "";
      filtered.forEach((card) => blogList.appendChild(card));
    }

    searchInput.addEventListener("input", updateView);
    tagFilter.addEventListener("change", updateView);
    sortSelect.addEventListener("change", updateView);
  </script>

  <style>
    .controls {
      margin-bottom: 3rem;
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }
    input, select {
      padding: 0.5rem 0.75rem;
      border: 1px solid rgba(128, 128, 128, 0.2);
      border-radius: var(--border-radius);
      background-color: var(--bg);
      color: var(--text-primary);
    }
    .blog-list {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    .blog-item {
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(128, 128, 128, 0.1);
    }
    .blog-link {
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .blog-meta {
      font-size: 0.85rem;
      color: var(--text-secondary);
      margin-bottom: 0.5rem;
    }
    .blog-title {
      margin: 0 0 0.5rem;
      font-size: var(--text-xl);
      color: var(--text-primary);
      transition: color 0.2s;
    }
    .blog-desc {
      color: var(--text-secondary);
      margin: 0;
      font-size: var(--text-base);
    }
    .blog-link:hover .blog-title {
      color: var(--accent);
    }
    .tags {
      margin-top: 0.75rem;
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .tags span {
      background: rgba(128, 128, 128, 0.1);
      padding: 0.2rem 0.6rem;
      border-radius: 4px;
      font-size: 0.8rem;
      color: var(--text-secondary);
    }
  </style>
</MainLayout>
