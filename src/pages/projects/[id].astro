---
import { type CollectionEntry, getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import MainLayout from "../../layouts/MainLayout.astro";
import { getReadingTime } from "../../utils/readingTime";

export async function getStaticPaths() {
  const projectEntries = await getCollection("projects");
  return projectEntries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<"projects"> };
const { entry } = Astro.props;
const { Content } = await render(entry);
const readingTime = getReadingTime(entry.body || "");
---

<MainLayout title={entry.data.title}>
  <article class="post">
    <header class="post-header">
      <span class="eyebrow">Project</span>
      <div class="post-meta">
        <time datetime={entry.data.date.toISOString()}>
          {entry.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </time>
        <span class="meta-dot">•</span>
        <span>{readingTime} min read</span>
      </div>
      <h1>{entry.data.title}</h1>
      <hr class="accent-rule" />
      <p class="post-description">{entry.data.description}</p>
      <div class="post-tags">
        {entry.data.tags.map(tag => <span>{tag}</span>)}
      </div>
      {(entry.data.link || entry.data.github) && (
        <div class="post-buttons">
          {entry.data.link && (
            <a href={entry.data.link} target="_blank" rel="noopener noreferrer" class="button">
              View project
            </a>
          )}
          {entry.data.github && (
            <a href={entry.data.github} target="_blank" rel="noopener noreferrer" class="button button-secondary">
              Source
            </a>
          )}
        </div>
      )}
    </header>

    {entry.data.coverImage && (
      <div class="post-cover">
        <Image src={entry.data.coverImage} alt={entry.data.title} width={720} height={405} />
      </div>
    )}

    <div class="post-content">
      <Content />
    </div>
  </article>

  <style>
    .post {
      max-width: var(--max-width);
      margin: 0 auto;
    }

    .post-header {
      margin-bottom: var(--space-2xl);
    }

    .post-meta {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      font-size: var(--text-xs);
      color: var(--text-muted);
      margin-bottom: var(--space-md);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .meta-dot {
      color: var(--border);
    }

    .post-header h1 {
      font-size: var(--text-4xl);
      margin: 0 0 0;
      line-height: 1.2;
      color: var(--text-primary);
    }

    .post-description {
      font-size: var(--text-lg);
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0 0 var(--space-lg);
    }

    .post-tags {
      display: flex;
      gap: var(--space-sm);
      flex-wrap: wrap;
      margin-bottom: var(--space-lg);
    }

    .post-tags span {
      font-size: var(--text-xs);
      padding: 0.125rem 0.5rem;
      border: 1px solid var(--border);
      border-radius: var(--border-radius);
      color: var(--text-secondary);
      font-weight: 500;
      background-color: transparent;
    }

    .post-buttons {
      display: flex;
      gap: var(--space-sm);
      flex-wrap: wrap;
    }

    .post-cover {
      margin-bottom: var(--space-2xl);
      border: 1px solid var(--border);
      border-radius: var(--border-radius);
      overflow: hidden;
    }

    .post-cover :global(img) {
      width: 100%;
      height: auto;
      display: block;
    }

    .post-content {
      font-size: var(--text-base);
      line-height: 1.8;
      max-width: var(--max-width);
    }

    .post-content :global(h2) {
      font-size: var(--text-2xl);
      margin-top: var(--space-2xl);
      margin-bottom: var(--space-md);
    }

    .post-content :global(h3) {
      font-size: var(--text-xl);
      margin-top: var(--space-xl);
      margin-bottom: var(--space-md);
    }

    .post-content :global(p) {
      margin-bottom: var(--space-lg);
      color: var(--text-secondary);
    }

    .post-content :global(a) {
      color: var(--accent);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .post-content :global(a:hover) {
      color: var(--accent-hover);
    }

    .post-content :global(ul),
    .post-content :global(ol) {
      margin-bottom: var(--space-lg);
      padding-left: var(--space-xl);
      color: var(--text-secondary);
    }

    .post-content :global(li) {
      margin-bottom: var(--space-sm);
    }

    .post-content :global(blockquote) {
      margin: var(--space-xl) 0;
      padding: var(--space-sm) var(--space-xl);
      background-color: transparent;
      border-left: 3px solid var(--accent);
      border-radius: 0;
      font-style: italic;
      color: var(--text-secondary);
    }

    .post-content :global(code) {
      font-family: var(--font-mono);
      font-size: 0.9em;
      padding: 0.15em 0.35em;
      background-color: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: var(--border-radius);
    }

    .post-content :global(pre) {
      margin: var(--space-xl) 0;
      padding: var(--space-lg);
      background-color: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: var(--border-radius);
      overflow-x: auto;
    }

    .post-content :global(pre code) {
      padding: 0;
      background: none;
      border: none;
      font-size: var(--text-sm);
    }

    .post-content :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: var(--border-radius);
      margin: var(--space-xl) 0;
    }

    @media (max-width: 768px) {
      .post-header h1 {
        font-size: var(--text-3xl);
      }

      .post-meta {
        flex-wrap: wrap;
      }
    }
  </style>
</MainLayout>
