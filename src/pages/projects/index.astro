---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { getReadingTime } from "../../utils/readingTime";

const allProjects = await getCollection("projects");
const allTags = [...new Set(allProjects.flatMap((p) => p.data.tags))].sort();
---

<MainLayout title="Projects">
  <div class="page-header">
    <span class="eyebrow">Work</span>
    <h1>Projects</h1>
    <hr class="rule" />
    <p class="page-description">A collection of things I've built and experimented with.</p>
  </div>

  <section class="controls">
    <div class="search-wrapper">
      <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input type="text" id="search-input" placeholder="Search projects..." />
    </div>
    <select id="tag-filter">
      <option value="all">All Tags</option>
      {allTags.map((tag) => <option value={tag}>{tag}</option>)}
    </select>
    <select id="sort-select">
      <option value="newest">Newest First</option>
      <option value="oldest">Oldest First</option>
      <option value="title">Alphabetical</option>
    </select>
  </section>

  <ul class="project-list" id="projects-list">
    {
      allProjects
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
        .map((project) => (
          <li class="project-card" data-tags={project.data.tags.join(" ")} data-title={project.data.title} data-date={project.data.date.getTime()}>
            <a href={`/projects/${project.id}`} class="project-link">
              {project.data.coverImage && (
                <div class="project-image">
                  <Image src={project.data.coverImage} alt={project.data.title} width={1200} height={675} widths={[360, 600, 900, 1200]} sizes="(max-width: 768px) 100vw, 380px" quality={90} loading="lazy" />
                </div>
              )}
              <div class="project-content">
                <div class="project-meta">
                  <time datetime={project.data.date.toISOString()}>
                    {project.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                  </time>
                  <span class="meta-dot">•</span>
                  <span>{getReadingTime(project.body || "")} min read</span>
                </div>
                <h3>{project.data.title}</h3>
                <p>{project.data.description}</p>
                <div class="project-tags">
                  {project.data.tags.map((tag) => <span>{tag}</span>)}
                </div>
              </div>
            </a>
          </li>
        ))
    }
  </ul>

  <style>
    .page-header {
      margin-bottom: var(--space-2xl);
    }

    .page-header h1 {
      margin: 0 0 0;
    }

    .page-description {
      color: var(--text-secondary);
      font-size: var(--text-lg);
      margin: 0;
    }

    .controls {
      margin-bottom: var(--space-2xl);
      display: flex;
      gap: var(--space-md);
      flex-wrap: wrap;
      padding: var(--space-md);
      background-color: var(--bg);
      border-radius: var(--border-radius);
      border: 1px solid var(--border);
    }

    .search-wrapper {
      position: relative;
      flex: 1;
      min-width: 200px;
    }

    .search-icon {
      position: absolute;
      left: var(--space-md);
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-muted);
      pointer-events: none;
    }

    input, select {
      padding: 0.375rem var(--space-md);
      border: 1px solid var(--border);
      border-radius: var(--border-radius);
      background-color: var(--bg);
      color: var(--text-primary);
      font-size: var(--text-sm);
      transition: border-color var(--transition-fast);
      width: 100%;
    }

    .search-wrapper input {
      padding-left: var(--space-2xl);
    }

    input:focus, select:focus {
      outline: none;
      border-color: var(--accent);
    }

    select {
      cursor: pointer;
      min-width: 140px;
      width: auto;
    }

    .project-list {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: var(--space-xl);
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .project-card {
      border-radius: var(--border-radius-lg);
      overflow: hidden;
      background-color: var(--bg);
      border: 1px solid var(--border);
      border-top: 2px solid var(--accent);
      transition: border-color var(--transition-fast);
    }

    .project-card:hover {
      border-color: var(--border-hover);
      border-top-color: var(--accent);
    }

    .project-link {
      text-decoration: none;
      color: inherit;
      display: block;
      height: 100%;
    }

    .project-image {
      aspect-ratio: 16 / 9;
      overflow: hidden;
      background-color: var(--bg-secondary);
    }

    .project-image :global(img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .project-content {
      padding: var(--space-lg);
    }

    .project-meta {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      font-size: var(--text-xs);
      color: var(--text-muted);
      margin-bottom: var(--space-sm);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .meta-dot {
      color: var(--border);
    }

    .project-content h3 {
      margin: 0 0 var(--space-sm);
      font-size: var(--text-lg);
      line-height: 1.3;
      transition: color var(--transition-fast);
    }

    .project-card:hover .project-content h3 {
      color: var(--accent);
    }

    .project-content p {
      margin: 0 0 var(--space-md);
      color: var(--text-secondary);
      font-size: var(--text-sm);
      line-height: 1.6;
    }

    .project-tags {
      display: flex;
      gap: var(--space-sm);
      flex-wrap: wrap;
    }

    .project-tags span {
      font-size: var(--text-xs);
      padding: 0.125rem 0.5rem;
      border: 1px solid var(--border);
      border-radius: var(--border-radius);
      color: var(--text-secondary);
      background-color: transparent;
    }

    @media (max-width: 768px) {
      .project-list {
        grid-template-columns: 1fr;
      }

      .controls {
        flex-direction: column;
      }

      select {
        width: 100%;
      }
    }
  </style>

  <script>
    const searchInput = document.getElementById("search-input") as HTMLInputElement;
    const tagFilter = document.getElementById("tag-filter") as HTMLSelectElement;
    const sortSelect = document.getElementById("sort-select") as HTMLSelectElement;
    const projectList = document.getElementById("projects-list") as HTMLUListElement;
    let projectCards = Array.from(document.querySelectorAll(".project-card")) as HTMLElement[];

    function updateView() {
      const searchTerm = searchInput.value.toLowerCase();
      const selectedTag = tagFilter.value;
      const sortBy = sortSelect.value;

      let filtered = projectCards.filter((card) => {
        const title = card.getAttribute("data-title")!.toLowerCase();
        const tags = card.getAttribute("data-tags")!;
        const matchesSearch = title.includes(searchTerm);
        const matchesTag = selectedTag === "all" || tags.split(" ").includes(selectedTag);
        return matchesSearch && matchesTag;
      });

      filtered.sort((a, b) => {
        if (sortBy === "newest") return parseInt(b.getAttribute("data-date")!) - parseInt(a.getAttribute("data-date")!);
        if (sortBy === "oldest") return parseInt(a.getAttribute("data-date")!) - parseInt(b.getAttribute("data-date")!);
        if (sortBy === "title") return a.getAttribute("data-title")!.localeCompare(b.getAttribute("data-title")!);
        return 0;
      });

      projectList.innerHTML = "";
      filtered.forEach((card) => projectList.appendChild(card));
    }

    searchInput.addEventListener("input", updateView);
    tagFilter.addEventListener("change", updateView);
    sortSelect.addEventListener("change", updateView);
  </script>
</MainLayout>
