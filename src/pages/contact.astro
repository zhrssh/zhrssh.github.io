---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE_CONFIG } from '../config';

const whatsappUrl = `https://wa.me/${SITE_CONFIG.socials.whatsapp}`;
const viberUrl = `viber://chat?number=${encodeURIComponent(SITE_CONFIG.socials.viber)}`;
---

<MainLayout title="Contact Me">
  <section class="contact-hero">
    <span class="eyebrow">Contact</span>
    <h1>Let's work together</h1>
    <hr class="accent-rule" />
    <p class="contact-intro">
      Got a workflow to automate? Tell me about your project
      and I'll get back to you within a day or two. Prefer to reach out directly? Use the
      channels on the right.
    </p>
  </section>

  <div class="contact-grid">
    <div class="form-column">
      <form id="contact-form" novalidate>
        <div class="field-row">
          <div class="field">
            <label for="first_name">First name</label>
            <input type="text" id="first_name" name="first_name" required autocomplete="given-name" />
          </div>
          <div class="field">
            <label for="last_name">Last name</label>
            <input type="text" id="last_name" name="last_name" required autocomplete="family-name" />
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required autocomplete="email" />
          </div>
          <div class="field">
            <label for="phone">Phone <span class="optional">(optional)</span></label>
            <input type="tel" id="phone" name="phone" autocomplete="tel" />
          </div>
        </div>

        <div class="field">
          <label for="subject">Subject</label>
          <input type="text" id="subject" name="subject" required />
        </div>

        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>

        <!-- Honeypot spam trap - real users won't fill this in -->
        <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" class="honeypot" />

        <button type="submit" id="submit-btn" class="button">
          <span class="btn-label">Send message</span>
        </button>

        <p class="consent-note">
          By sending this message, you agree to our
          <a href="/privacy-policy">Privacy Policy</a>.
        </p>

        <p id="form-success" class="form-message form-success" hidden>
          Thanks — your message has been sent. I'll reply to <span id="confirm-email"></span> shortly.
        </p>
        <p id="form-error" class="form-message form-error" hidden>
          Something went wrong sending your message. Please try again, or email me directly at
          <a href={`mailto:${SITE_CONFIG.email}`}>{SITE_CONFIG.email}</a>.
        </p>
      </form>
    </div>

    <aside class="channels-column">
      <span class="eyebrow">Direct channels</span>
      <h2>Reach me directly</h2>
      <hr class="rule" />
      <p class="channels-intro">
        No form required — pick whatever's easiest for you.
      </p>
      <div class="link-pills">
        <a href={`mailto:${SITE_CONFIG.email}`} class="link-pill">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          Email
        </a>
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="link-pill">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-1.045zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.625.712.227 1.362.195 1.875.118.572-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
          WhatsApp
        </a>
        <a href={viberUrl} target="_blank" rel="noopener noreferrer" class="link-pill">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M11.4 0C9.473.028 5.333.344 3.02 2.467 1.302 4.187.696 6.7.633 9.817.57 12.933.488 18.776 6.12 20.36h.003l-.004 2.416s-.037.977.61 1.177c.777.242 1.234-.5 1.98-1.302.407-.44.972-1.084 1.397-1.58 3.85.326 6.812-.416 7.15-.525.776-.252 5.176-.816 5.892-6.657.74-6.02-.36-9.83-2.34-11.546-.596-.55-3.006-2.3-8.375-2.323 0 0-.395-.025-1.037-.017zm.058 1.693c.545-.004.88.017.88.017 4.542.02 6.717 1.388 7.222 1.846 1.675 1.435 2.53 4.868 1.906 9.897v.002c-.604 4.878-4.174 5.184-4.832 5.395-.28.09-2.882.737-6.153.524 0 0-2.436 2.94-3.197 3.704-.12.12-.26.167-.352.144-.13-.033-.166-.188-.165-.414l.02-4.018c-4.762-1.32-4.485-6.292-4.43-8.895.054-2.604.543-4.738 1.996-6.173 1.96-1.773 5.474-2.018 7.11-2.03zm.38 2.602c-.167 0-.303.135-.304.302 0 .167.133.303.3.305 1.624.01 2.946.537 4.028 1.592 1.073 1.046 1.62 2.468 1.633 4.334.002.167.14.3.307.3.166-.002.3-.138.3-.304-.014-1.984-.618-3.596-1.816-4.764-1.19-1.16-2.692-1.753-4.447-1.765zm-3.96.695c-.19-.032-.4.005-.616.117l-.01.002c-.43.247-.816.562-1.146.932-.002.004-.006.004-.008.008-.267.323-.42.638-.46.948-.008.046-.01.093-.007.14 0 .136.022.27.065.4l.013.01c.135.48.473 1.276 1.205 2.604.42.768.903 1.5 1.446 2.186.27.344.56.673.87.984l.132.132c.31.308.64.6.984.87.686.543 1.418 1.027 2.186 1.447 1.328.733 2.126 1.07 2.604 1.206l.01.014c.13.042.265.064.402.063.046.002.092 0 .138-.008.31-.036.627-.19.948-.46.004 0 .003-.002.008-.005.37-.33.683-.72.93-1.148l.003-.01c.225-.432.15-.842-.18-1.12-.004 0-.698-.58-1.037-.83-.36-.255-.73-.492-1.113-.71-.51-.285-1.032-.106-1.248.174l-.447.564c-.23.283-.657.246-.657.246-3.12-.796-3.955-3.955-3.955-3.955s-.037-.426.248-.656l.563-.448c.277-.215.456-.737.17-1.248-.217-.383-.454-.756-.71-1.115-.25-.34-.826-1.033-.83-1.035-.137-.165-.31-.265-.502-.297zm4.49.88c-.158.002-.29.124-.3.282-.01.167.115.312.282.324 1.16.085 2.017.466 2.645 1.15.63.688.93 1.524.906 2.57-.002.168.13.306.3.31.166.003.305-.13.31-.297.025-1.175-.334-2.193-1.067-2.994-.74-.81-1.777-1.253-3.05-1.346h-.024zm.463 1.63c-.16.002-.29.127-.3.287-.008.167.12.31.288.32.523.028.875.175 1.113.422.24.245.388.62.416 1.164.01.167.15.295.318.287.167-.008.295-.15.287-.317-.03-.644-.215-1.178-.58-1.557-.367-.378-.893-.574-1.52-.607h-.018z"/></svg>
          Viber
        </a>
        <a href={SITE_CONFIG.socials.github} target="_blank" rel="noopener noreferrer" class="link-pill">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
          GitHub
        </a>
        <a href={SITE_CONFIG.socials.linkedin} target="_blank" rel="noopener noreferrer" class="link-pill">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          LinkedIn
        </a>
      </div>

      <div class="contact-meta">
        <div class="meta-row">
          <span class="meta-label">Email</span>
          <a href={`mailto:${SITE_CONFIG.email}`} class="meta-value">{SITE_CONFIG.email}</a>
        </div>
        <div class="meta-row">
          <span class="meta-label">Phone</span>
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="meta-value">{SITE_CONFIG.phone}</a>
        </div>
        <div class="meta-row">
          <span class="meta-label">Viber</span>
          <a href={viberUrl} class="meta-value">{SITE_CONFIG.socials.viber}</a>
        </div>
        <div class="meta-row">
          <span class="meta-label">Based in</span>
          <span class="meta-value">Philippines · Remote worldwide</span>
        </div>
      </div>
    </aside>
  </div>

  <style>
    .contact-hero {
      margin-bottom: var(--space-2xl);
    }

    .contact-hero h1 {
      margin: 0 0 0;
      color: var(--text-primary);
    }

    .contact-intro {
      font-size: var(--text-base);
      color: var(--text-secondary);
      margin: 0;
      line-height: 1.7;
      max-width: 60ch;
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
      align-items: stretch;
    }

    .form-column {
      padding: var(--space-2xl);
      border: 1px solid var(--border);
      border-top: 2px solid var(--accent);
      border-radius: var(--border-radius-lg);
      background-color: var(--bg);
    }

    .field-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-md);
      margin-bottom: var(--space-lg);
    }

    .field {
      margin-bottom: var(--space-lg);
    }

    .field-row .field {
      margin-bottom: 0;
    }

    @media (max-width: 480px) {
      .field-row {
        grid-template-columns: 1fr;
        gap: var(--space-lg);
      }
    }

    .field label {
      display: block;
      font-size: var(--text-sm);
      font-weight: 500;
      color: var(--text-primary);
      margin-bottom: var(--space-xs);
    }

    .field .optional {
      font-weight: 400;
      color: var(--text-muted);
      font-size: var(--text-xs);
    }

    .field input,
    .field textarea {
      width: 100%;
      padding: 0.625rem 0.75rem;
      font-family: inherit;
      font-size: var(--text-base);
      color: var(--text-primary);
      background-color: transparent;
      border: 1px solid var(--border);
      border-radius: var(--border-radius);
      transition: border-color var(--transition-fast);
    }

    .field textarea {
      resize: vertical;
      min-height: 120px;
      line-height: 1.6;
    }

    .field input:focus,
    .field textarea:focus {
      outline: none;
      border-color: var(--accent);
    }

    .field input:focus-visible,
    .field textarea:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 1px;
    }

    .honeypot {
      position: absolute;
      left: -9999px;
      width: 1px;
      height: 1px;
      overflow: hidden;
      opacity: 0;
    }

    #submit-btn {
      width: 100%;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.75rem var(--space-lg);
      font-family: inherit;
      font-size: var(--text-base);
      font-weight: 500;
      border-radius: var(--border-radius);
      border: 1px solid var(--accent);
      background-color: var(--accent);
      color: var(--bg);
      transition: background-color var(--transition-fast), border-color var(--transition-fast);
    }

    #submit-btn:hover:not(:disabled) {
      background-color: var(--accent-hover);
      border-color: var(--accent-hover);
    }

    #submit-btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .form-message {
      margin-top: var(--space-lg);
      padding: var(--space-md);
      border-radius: var(--border-radius);
      font-size: var(--text-sm);
      line-height: 1.6;
    }

    .form-success {
      background-color: rgba(34, 197, 94, 0.1);
      border: 1px solid rgba(34, 197, 94, 0.4);
      color: var(--text-primary);
    }

    .form-error {
      background-color: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.4);
      color: var(--text-primary);
    }

    .form-error a {
      color: var(--accent);
    }

    .consent-note {
      margin-top: var(--space-md);
      font-size: var(--text-xs);
      color: var(--text-muted);
      line-height: 1.5;
    }

    .consent-note a {
      color: var(--accent);
      text-decoration: none;
    }

    .consent-note a:hover {
      color: var(--accent-hover);
      text-decoration: underline;
    }

    .channels-column {
      padding: var(--space-2xl);
      border: 1px solid var(--border);
      border-radius: var(--border-radius-lg);
      background-color: var(--bg);
    }

    .channels-column h2 {
      margin: 0 0 0;
      font-size: var(--text-xl);
    }

    .channels-intro {
      color: var(--text-secondary);
      font-size: var(--text-sm);
      margin: 0 0 var(--space-lg);
      line-height: 1.6;
    }

    .link-pills {
      display: flex;
      gap: var(--space-sm);
      flex-wrap: wrap;
      margin-bottom: var(--space-2xl);
    }

    .link-pill {
      display: inline-flex;
      align-items: center;
      gap: var(--space-sm);
      color: var(--text-secondary);
      text-decoration: none;
      padding: 0.5rem var(--space-md);
      border: 1px solid var(--border);
      border-radius: var(--border-radius);
      font-size: var(--text-sm);
      font-weight: 500;
      transition: color var(--transition-fast), border-color var(--transition-fast);
    }

    .link-pill:hover {
      color: var(--accent);
      border-color: var(--accent);
    }

    .contact-meta {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
      padding-top: var(--space-lg);
      border-top: 1px solid var(--border);
    }

    .meta-row {
      display: flex;
      flex-direction: column;
      gap: 0.125rem;
    }

    .meta-label {
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-muted);
    }

    .meta-value {
      font-size: var(--text-sm);
      color: var(--text-primary);
      text-decoration: none;
      transition: color var(--transition-fast);
    }

    a.meta-value:hover {
      color: var(--accent);
    }

    .accent-rule {
      border: none;
      border-top: 2px solid var(--accent);
      width: 3rem;
      margin: var(--space-sm) 0 var(--space-lg);
    }

    .rule {
      border: none;
      border-top: 1px solid var(--border);
      margin: var(--space-sm) 0 var(--space-md);
    }

    @media (max-width: 768px) {
      .contact-grid {
        grid-template-columns: 1fr;
      }

      .form-column,
      .channels-column {
        padding: var(--space-xl);
      }
    }
  </style>

  <script is:inline define:vars={{ accessKey: SITE_CONFIG.contact.formAccessKey }}>
    const form = document.getElementById("contact-form");
    const submitBtn = document.getElementById("submit-btn");
    const btnLabel = submitBtn.querySelector(".btn-label");
    const successEl = document.getElementById("form-success");
    const errorEl = document.getElementById("form-error");
    const confirmEmail = document.getElementById("confirm-email");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      successEl.hidden = true;
      errorEl.hidden = true;

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());

      // Honeypot: silently drop if filled
      if (payload.botcheck) {
        return;
      }

      payload.access_key = accessKey;
      delete payload.botcheck;

      submitBtn.disabled = true;
      btnLabel.textContent = "Sending…";

      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify(payload),
        });
        const data = await res.json();

        if (data.success) {
          confirmEmail.textContent = payload.email;
          successEl.hidden = false;
          form.reset();
        } else {
          errorEl.hidden = false;
        }
      } catch (err) {
        errorEl.hidden = false;
      } finally {
        submitBtn.disabled = false;
        btnLabel.textContent = "Send message";
      }
    });
  </script>
</MainLayout>