---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE_CONFIG } from '../config';

const skillCols = Math.min(SITE_CONFIG.skills.length, 3);
const certCols = Math.min(SITE_CONFIG.certifications.length, 2);
---

<MainLayout title="About Me">
  <div class="about-hero">
    <div class="about-hero-content">
      <img src="/me.jpg" alt="Zherish" class="profile-img" />
      <div class="about-hero-text">
        <h1>About Me</h1>
        <p class="about-bio">
          I'm a software engineer and computer engineering graduate based in the Philippines, focused on automation and backend systems that take repetitive work off people's plates. Most recently I've built n8n workflows for businesses and trading algorithms in Python, after a research stint at DOST-ASTI. I care about clean, maintainable code and tools that genuinely save people time.
        </p>
      </div>
    </div>
  </div>

  <section class="about-section">
    <h2>What I Do</h2>
    <p>I love crafting clean code and solving complex technical challenges. With a focus on modern web technologies, I build applications that are fast, accessible, and delightful to use.</p>
  </section>

  <section class="about-section">
    <h2>Get in Touch</h2>
    <div class="actions">
      <a href={SITE_CONFIG.resumeUrl} download class="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        Download CV
      </a>
      <div class="socials">
        <a href={SITE_CONFIG.socials.github} target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
          GitHub
        </a>
        <a href={SITE_CONFIG.socials.linkedin} target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          LinkedIn
        </a>
        <a href={`mailto:${SITE_CONFIG.email}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          Email
        </a>
      </div>
    </div>
  </section>

  <section class="about-section">
    <h2>Technical Skills</h2>
    <div class="skills-grid" data-cols={skillCols}>
      {SITE_CONFIG.skills.map(skill => (
        <div class="skill-card">
          <span>{skill}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="about-section">
    <h2>Experience</h2>
    <div class="timeline">
      {SITE_CONFIG.experience.map(exp => (
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-header">
              <h3>{exp.role}</h3>
              <span class="timeline-duration">{exp.duration}</span>
            </div>
            <p class="timeline-company">{exp.company}</p>
            <ul class="timeline-list">
              {exp.description.map(desc => <li>{desc}</li>)}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="about-section">
    <h2>Education</h2>
    <div class="timeline">
      {SITE_CONFIG.education.map(edu => (
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-header">
              <h3>{edu.degree}</h3>
              <span class="timeline-duration">{edu.year}</span>
            </div>
            <p class="timeline-company">{edu.institution}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="about-section">
    <h2>Certifications</h2>
    <div class="certs-grid" data-cols={certCols}>
      {SITE_CONFIG.certifications.map(cert => (
        <div class="cert-card">
          <h3>{cert.name}</h3>
          <div class="cert-meta">
            <span>{cert.issuer}</span>
            <span class="cert-dot">•</span>
            <span>{cert.year}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <style>
    .about-hero {
      margin-bottom: var(--space-3xl);
    }

    .about-hero-content {
      display: flex;
      align-items: center;
      gap: var(--space-2xl);
      max-width: 1200px;
    }

    .profile-img {
      width: 200px;
      height: 200px;
      flex-shrink: 0;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid var(--bg-secondary);
      box-shadow: var(--shadow-lg);
    }

    .about-hero-text h1 {
      margin: 0 0 var(--space-sm);
    }

    .about-bio {
      color: var(--text-secondary);
      font-size: var(--text-base);
      margin: 0;
      line-height: 1.7;
    }

    .about-section {
      margin-bottom: var(--space-3xl);
    }

    .about-section:last-child {
      margin-bottom: 0;
    }

    .about-section h2 {
      margin-bottom: var(--space-lg);
      padding-bottom: var(--space-sm);
      border-bottom: 2px solid var(--border);
    }

    .about-section p {
      color: var(--text-secondary);
      line-height: 1.8;
    }

    .actions {
      display: flex;
      align-items: center;
      gap: var(--space-lg);
      flex-wrap: wrap;
    }

    .socials {
      display: flex;
      gap: var(--space-md);
      flex-wrap: wrap;
    }

    .socials a {
      display: inline-flex;
      align-items: center;
      gap: var(--space-sm);
      color: var(--text-secondary);
      text-decoration: none;
      padding: var(--space-sm) var(--space-md);
      border: 1px solid var(--border);
      border-radius: var(--border-radius);
      font-size: var(--text-sm);
      font-weight: 500;
      transition: all var(--transition-fast);
    }

    .socials a:hover {
      color: var(--accent);
      border-color: var(--accent);
      background-color: rgba(249, 115, 22, 0.05);
      transform: translateY(-2px);
    }

    [data-theme='dark'] .socials a:hover {
      background-color: rgba(251, 146, 60, 0.1);
    }

    .skills-grid {
      display: grid;
      gap: var(--space-md);
    }

    .skills-grid[data-cols="1"] {
      max-width: 640px;
      grid-template-columns: 1fr;
    }

    .skills-grid[data-cols="2"] {
      max-width: 720px;
      grid-template-columns: repeat(2, 1fr);
    }

    .skills-grid[data-cols="3"] {
      grid-template-columns: repeat(3, 1fr);
    }

    .skill-card {
      padding: var(--space-md);
      background-color: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: var(--border-radius);
      text-align: center;
      font-weight: 500;
      font-size: var(--text-sm);
      transition: all var(--transition-fast);
    }

    .skill-card:hover {
      border-color: var(--accent);
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    .timeline {
      position: relative;
      padding-left: var(--space-xl);
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: 7px;
      top: 8px;
      bottom: 8px;
      width: 2px;
      background-color: var(--border);
    }

    .timeline-item {
      position: relative;
      padding-bottom: var(--space-xl);
    }

    .timeline-item:last-child {
      padding-bottom: 0;
    }

    .timeline-dot {
      position: absolute;
      left: -25px;
      top: 8px;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background-color: var(--accent);
      border: 3px solid var(--bg);
      box-shadow: 0 0 0 2px var(--accent);
    }

    .timeline-content {
      background-color: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: var(--border-radius);
      padding: var(--space-lg);
    }

    .timeline-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: var(--space-md);
      margin-bottom: var(--space-xs);
      flex-wrap: wrap;
    }

    .timeline-header h3 {
      margin: 0;
      font-size: var(--text-lg);
    }

    .timeline-duration {
      font-size: var(--text-xs);
      color: var(--text-muted);
      background-color: var(--bg);
      padding: var(--space-xs) var(--space-sm);
      border-radius: 4px;
      white-space: nowrap;
    }

    .timeline-company {
      color: var(--text-secondary);
      font-size: var(--text-sm);
      margin: 0 0 var(--space-md);
    }

    .timeline-list {
      margin: 0;
      padding-left: var(--space-lg);
      color: var(--text-secondary);
      font-size: var(--text-sm);
      line-height: 1.7;
    }

    .timeline-list li {
      margin-bottom: var(--space-xs);
    }

    .certs-grid {
      display: grid;
      gap: var(--space-md);
    }

    .certs-grid[data-cols="1"] {
      max-width: 640px;
      grid-template-columns: 1fr;
    }

    .certs-grid[data-cols="2"] {
      max-width: 720px;
      grid-template-columns: repeat(2, 1fr);
    }

    .cert-card {
      padding: var(--space-lg);
      background-color: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: var(--border-radius);
      transition: all var(--transition-fast);
    }

    .cert-card:hover {
      border-color: var(--accent);
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    .cert-card h3 {
      margin: 0 0 var(--space-sm);
      font-size: var(--text-base);
      line-height: 1.4;
    }

    .cert-meta {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      font-size: var(--text-xs);
      color: var(--text-muted);
      flex-wrap: wrap;
    }

    .cert-dot {
      color: var(--border);
    }

    @media (max-width: 1024px) {
      .skills-grid[data-cols="3"] {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 768px) {
      .about-hero-content {
        flex-direction: column;
        text-align: center;
        align-items: center;
      }

      .skills-grid {
        grid-template-columns: 1fr !important;
      }

      .skills-grid[data-cols="1"],
      .skills-grid[data-cols="2"] {
        max-width: 640px;
      }

      .certs-grid {
        grid-template-columns: 1fr !important;
      }

      .certs-grid[data-cols="1"],
      .certs-grid[data-cols="2"] {
        max-width: 640px;
      }

      .timeline-header {
        flex-direction: column;
        gap: var(--space-xs);
      }
    }
  </style>
</MainLayout>
